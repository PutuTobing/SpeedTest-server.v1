# SpeedTest Service Configuration

# Port to listen on (default: 8080)
PORT=8080

# IP address to bind to (default: 0.0.0.0 for all interfaces)
# You can set specific IP for multi-IP servers
BIND_IP=0.0.0.0

# Node name for identification
NODE_NAME=SpeedTest-Jakarta

# Buffer size in bytes for download/upload (default: 1048576 = 1MB)
# Larger buffer = better performance but more memory
BUFFER_SIZE=1048576

# Request timeout (default: 30s)
TIMEOUT=30s
